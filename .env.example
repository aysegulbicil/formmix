# FORMMIX canlı ortam örneği
# Bu dosyayı .env adıyla kopyalayın ve gerçek değerleri yalnızca sunucuda doldurun.

CI_ENVIRONMENT = production

app.baseURL = 'https://ornek-alan-adiniz.com/'
app.indexPage = ''
app.forceGlobalSecureRequests = true

database.default.hostname = 127.0.0.1
database.default.database = formmix
database.default.username = formmix_user
database.default.password = GUCLU_BIR_VERITABANI_SIFRESI_YAZIN
database.default.DBDriver = MySQLi
database.default.port = 3306

cookie.secure = true
cookie.httponly = true
cookie.samesite = Lax

email.protocol = smtp
email.SMTPHost = smtp.example.com
email.SMTPUser = bildirim@example.com
email.SMTPPass = SMTP_UYGULAMA_SIFRESI
email.SMTPPort = 587
email.SMTPCrypto = tls
email.fromEmail = bildirim@example.com
email.fromName = FORMMIX
email.mailType = html
